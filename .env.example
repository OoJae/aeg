# Pick ONE provider option. See the README Quickstart for the matching walkthrough.
#
# ============================================================================
# OPTION A — OpenAI (one key, simplest). Uncomment these three lines and DELETE
# the whole EMBEDDING_* block below — the same key covers embeddings (cognee's
# default). This is the smoothest path if you have an OpenAI key.
# ============================================================================
# LLM_PROVIDER="openai"
# LLM_MODEL="openai/gpt-5-mini"
# LLM_API_KEY="sk-..."

# ============================================================================
# OPTION B — any OpenAI-compatible endpoint + local embeddings (what Aeg was
# built and run on: MiMo v2.5 Pro). The openai/ prefix on LLM_MODEL tells litellm
# to speak the OpenAI protocol against LLM_ENDPOINT. Keep the EMBEDDING_* block.
# ============================================================================
LLM_PROVIDER="custom"
LLM_MODEL="openai/mimo-v2.5-pro"
LLM_ENDPOINT="https://token-plan-sgp.xiaomimimo.com/v1"
LLM_API_KEY="tp-..."

# --- Embeddings (Option B only) ---
# Local fastembed (no API key) — required for LLM endpoints that only serve chat
# completions. Without it, cognee would send LLM_API_KEY to OpenAI embeddings and
# fail. First run downloads a ~90 MB MiniLM model. DELETE this block for Option A.
EMBEDDING_PROVIDER="fastembed"
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING_DIMENSIONS="384"

# --- Aeg profile switches (embedded is the default; others are later-phase) ---
# AEG_PROFILE="embedded"            # embedded | postgres | cloud
# AEG_COGNEE_URL=""                 # Cognee Cloud: cognee.serve(url=..., api_key=...)
# AEG_COGNEE_API_KEY=""

# --- Phase-6 Postgres profile (relational + vector on Postgres/pgvector) ---
# 1) uv sync --extra postgres   2) docker compose up -d   3) AEG_PROFILE=postgres
# AEG_PROFILE="postgres"
# AEG_PG_HOST="localhost"  AEG_PG_PORT="5432"  AEG_PG_NAME="cognee"
# AEG_PG_USER="cognee"     AEG_PG_PASSWORD="cognee"

# --- Phase-6 stretch feature flags (defaults shown) ---
# AEG_ANTIBODIES_ENABLED="true"     # block replayed attacks instantly
# AEG_TRUTH_SUBSPACE="false"        # rerank recall toward validated truth (experimental)
# AEG_MULTI_USER="false"            # per-user dataset namespacing (organizational only)

# --- Security / abuse-resistance (the gateway is a public, paid-LLM service) ---
# Leave AEG_API_KEY UNSET for the open demo. SET it for any self-host/prod run:
# mutating/LLM routes then require the `X-Aeg-Key` header, POST /demo/reset becomes
# admin-only, and the API docs are hidden.
# AEG_API_KEY=""                    # shared-secret; unset => open demo mode
# AEG_TRUST_CLIENT_KIND="true"      # false => ignore client source.kind (all ingress untrusted)
# AEG_RATE_LIMIT="20"               # per-IP requests per window (<=0 disables)
# AEG_RATE_WINDOW_SECONDS="300"
# AEG_DAILY_LLM_BUDGET="2000"       # hard cap on LLM calls/day (503 over) — wallet kill-switch
# AEG_MAX_CONTENT_CHARS="8000"      # max /remember content length
# AEG_MAX_DATASETS="128"            # bound distinct datasets tracked in memory

# --- Persistence (production) ---
# Point this at a PERSISTENT volume (not /tmp) so memory survives restarts.
# The Railway deploy sets AEG_SCRATCH_DIR to its mounted volume.
# AEG_SCRATCH_DIR="/data/cognee"
